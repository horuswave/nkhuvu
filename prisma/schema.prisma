// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client"
  output     = "../generated/prisma"
  engineType = "client"
}



model AdminUser {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  name         String
  isSuperAdmin Boolean      @default(false)
  createdAt    DateTime     @default(now())
  eventAdmins  EventAdmin[]
  subscription Subscription?
}

model EventAdmin {
  id          String    @id @default(cuid())
  adminUserId String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  eventId     String
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([adminUserId, eventId])
}

model Event {
  id           String   @id @default(cuid())
  title        String
  coupleNames  String
  date         DateTime
  time         String
  venue        String
  address      String
  mapUrl       String?
  dressCode    String?
  message      String?  @db.Text
  rules        String?  @db.Text
  supportEmail String?
  supportPhone String?

  // Branding
  primaryColor    String          @default("#c8890e")
  accentColor     String          @default("#0e0b07")
  heroImageUrl    String?
  logoUrl         String?
  fontDisplay     String          @default("Cormorant Garamond")
  fontBody        String          @default("Jost")
  backgroundStyle BackgroundStyle @default(DARK)

  // Program timeline — ordered array of { id, type, label, time, notes? }
  programItems Json @default("[]")

  // Gift list — ordered array of GiftItem objects (see GiftListEditor.tsx for shape)
  giftList Json @default("[]")

  // RSVP form field visibility — { companions, dietary, transport, message }
  rsvpFields Json @default("{\"companions\":true,\"dietary\":true,\"transport\":true,\"message\":true}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guests      Guest[]
  tables      Table[]
  eventAdmins EventAdmin[]
}

model Guest {
  id               String        @id @default(cuid())
  eventId          String
  event            Event         @relation(fields: [eventId], references: [id])
  primaryName      String
  email            String?
  phone            String?
  preferredContact ContactMethod @default(EMAIL)
  token            String        @unique @default(uuid())
  maxAllowed       Int           @default(2)
  rsvpStatus       RsvpStatus    @default(PENDING)
  rsvpSubmittedAt  DateTime?
  tableId          String?
  table            Table?        @relation(fields: [tableId], references: [id])
  notes            String?       @db.Text
  isVip            Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  rsvp        Rsvp?
  companions  GuestCompanion[]
  messageLogs MessageLog[]
}

model Rsvp {
  id                  String   @id @default(cuid())
  guestId             String   @unique
  guest               Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  attending           Boolean
  totalAttending      Int      @default(1)
  dietaryRestrictions String?  @db.Text
  transportNotes      String?  @db.Text
  coupleMessage       String?  @db.Text
  ipAddress           String?
  submittedAt         DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model GuestCompanion {
  id                  String  @id @default(cuid())
  guestId             String
  guest               Guest   @relation(fields: [guestId], references: [id], onDelete: Cascade)
  name                String
  dietaryRestrictions String?
}

model Table {
  id       String  @id @default(cuid())
  eventId  String
  event    Event   @relation(fields: [eventId], references: [id])
  name     String
  capacity Int
  notes    String?
  guests   Guest[]
}

model MessageLog {
  id          String         @id @default(cuid())
  guestId     String
  guest       Guest          @relation(fields: [guestId], references: [id], onDelete: Cascade)
  channel     ContactMethod
  messageType MessageType
  sentAt      DateTime       @default(now())
  status      DeliveryStatus @default(SENT)
  externalId  String?
  errorDetail String?
}

model LandingLead {
  id              String   @id @default(cuid())
  
  // Visitor identification / session
  sessionId       String?  @unique  // e.g. a UUID you generate per visit
  ipAddress       String?
  userAgent       String?
  
  // Device info
  deviceType      String?  // "mobile" | "desktop" | "tablet"
  isMobile        Boolean  @default(false)
  mobileBrand     String?  // e.g. "Samsung", "Apple", "Huawei", "Xiaomi"
  deviceModel     String?  // e.g. "iPhone 15 Pro", "Galaxy S24"
  phoneSpec       String?  // Additional specs if you want (screen size, OS version, etc.)
  
  // Browser & OS
  browser         String?  // "Chrome", "Safari", "Firefox", etc.
  browserVersion  String?
  os              String?  // "Android", "iOS", "Windows", "macOS"
  
  // Location (from IP geolocation)
  country         String?
  countryCode     String?
  city            String?
  region          String?
  latitude        Float?
  longitude       Float?
  
  // Session / Engagement
  sessionStart    DateTime @default(now())
  sessionEnd      DateTime?
  sessionDuration Int?     // in seconds
  
  // Landing page context
  referrer        String?
  landingPageUrl  String?  // e.g. "/event/abc123" or general marketing page
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  
  // Interest signals
  viewedEventId   String?  // If they visited a specific event landing page
  timeOnPage      Int?     // seconds
  scrolledPercent Int?     // 0-100
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([createdAt])
  @@index([country])
  @@index([deviceType])
  @@index([mobileBrand])
}

model ContactLead {
  id           String    @id @default(cuid())
  email        String
  name         String?
  message      String?
  locale       String?
  isVerified   Boolean   @default(false)
  verifiedAt   DateTime?
  isAdminRequest Boolean @default(true)
  adminInviteToken String? @unique
  inviteSentAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  otps         ContactOtp[]

  @@index([email])
}

model ContactOtp {
  id           String    @id @default(cuid())
  contactLeadId String
  code         String
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime  @default(now())

  contactLead  ContactLead @relation(fields: [contactLeadId], references: [id], onDelete: Cascade)

  @@index([contactLeadId])
  @@index([code])
}

model Package {
  id          String   @id @default(cuid())
  name        String   @unique
  price       Float
  currency    String   @default("MZN")
  maxEvents   Int
  maxGuests   Int
  features    Json     @default("[]")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id           String    @id @default(cuid())
  adminUserId  String    @unique
  adminUser    AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  packageId    String
  package      Package   @relation(fields: [packageId], references: [id])
  status       SubscriptionStatus @default(ACTIVE)
  startDate    DateTime  @default(now())
  endDate      DateTime?
  mpesaTransactionId String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([adminUserId])
  @@index([packageId])
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}
enum ContactMethod {
  EMAIL
  WHATSAPP
  SMS
  MANUAL
}

enum RsvpStatus {
  PENDING
  ATTENDING
  DECLINED
  MAYBE
}

enum MessageType {
  INVITATION
  REMINDER
  CONFIRMATION
  CUSTOM
}

enum DeliveryStatus {
  SENT
  DELIVERED
  FAILED
  PENDING
}

enum BackgroundStyle {
  DARK
  LIGHT
  IMAGE
}
